# ForgeStack Frontend Environment Variables
# These variables are validated and loaded from src/config/env.ts.
# If you add, rename, or remove any variable here, make sure to update
# the schema in src/schema/env.schema.ts as well.

VITE_APP_NAME=ForgeStack

# Valid values: development | production | staging
VITE_APP_ENV=development

VITE_API_URL=https://api.example.com