{
  "name": "forgestack@server",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev:client": "pnpm --filter @forgestack/client dev",
    "dev:server": "pnpm --filter @forgestack/server start:dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.62.1"
  }
}
